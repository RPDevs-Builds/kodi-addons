<?xml version='1.0' encoding='utf-8'?>
<addons><addon id="metadata.anime.otaku.python" name="Otaku Anime Scraper" version="1.0.6" provider-name="YourName">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.metadata.scraper.tvshows" library="scraper.py">
        <provides>tvshows episodes</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Anime Metadata Indexer powered by AniList and Otaku Mappings</summary>
        <description>A high-performance scraper mapping Eastern Anime databases to native Kodi formats.</description>
        <platform>all</platform>
    </extension>
</addon><addon id="repository.rpdevs" name="RPDevs Kodi Add-on Repository" version="1.0.0" provider-name="RPDevs-Builds">
    <extension point="xbmc.addon.repository" name="RPDevs Kodi Add-on Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/RPDevs-Builds/kodi-addons/main/repo/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/RPDevs-Builds/kodi-addons/main/repo/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/RPDevs-Builds/kodi-addons/main/repo/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>RPDevs Kodi Add-on Repository</summary>
        <description>Official Kodi add-on repository for RPDevs-Builds. Hosts first-party scrapers, plugins, and curated third-party add-ons.</description>
        <disclaimer>Use at your own risk. Third-party add-ons are mirrored for convenience and are subject to their own licenses.</disclaimer>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon></addons>